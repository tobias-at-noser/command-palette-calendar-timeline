<Window x:Class="CalendarTimeline.Wpf.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:snapbar="clr-namespace:CalendarTimeline.Snapbar;assembly=CalendarTimeline.Snapbar"
          Title="Calendar Timeline"
          Height="48"
          Width="400"
          WindowStyle="None"
          ResizeMode="CanResize"
          Topmost="True"
          ShowInTaskbar="False"
          AllowsTransparency="True"
          Background="Transparent">
    <Grid x:Name="RootGrid"
          Background="#01000000"
        MouseEnter="OnRootMouseEnter"
        MouseLeave="OnRootMouseLeave"
        PreviewMouseLeftButtonDown="OnRootPreviewMouseLeftButtonDown">
    <Border x:Name="HoverSurface"
            Margin="12,6"
            Background="#55FFFFFF"
            BorderBrush="#BFFFFFFF"
            BorderThickness="1"
            CornerRadius="3"
            IsHitTestVisible="False"
            Opacity="0" />
    <Grid Margin="12,6">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid x:Name="TimelineGrid" Grid.Row="0">
        <Border x:Name="TimelineRail"
                Height="{x:Static snapbar:TimelineSnapbarLayout.RailHeight}"
                VerticalAlignment="Bottom"
                Margin="0,0,0,4">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="#001B2635" Offset="0" />
              <GradientStop Color="#CC6A8296" Offset="0.12" />
              <GradientStop Color="#CC6A8296" Offset="0.88" />
              <GradientStop Color="#001B2635" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <Border x:Name="NowLine"
                Width="2"
                HorizontalAlignment="Left"
                Background="White"
                VerticalAlignment="Bottom"
                Panel.ZIndex="1"
                IsHitTestVisible="False">
          <Border.Effect>
            <DropShadowEffect Color="#80000000" ShadowDepth="0" BlurRadius="2" Opacity="0.55" />
          </Border.Effect>
        </Border>
      <Canvas x:Name="BlocksCanvas" />
      </Grid>

      <TextBlock x:Name="StatusTextBlock"
                 Grid.Row="1"
                 Text="{Binding StatusText}"
                 Foreground="#B01B2635"
                 FontSize="10"
                 Margin="0,3,0,0" />
    </Grid>
  </Grid>
</Window>
