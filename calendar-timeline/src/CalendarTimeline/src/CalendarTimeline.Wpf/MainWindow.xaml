<Window x:Class="CalendarTimeline.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calendar Timeline"
        Height="96"
        Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#FF101820">
  <Grid Margin="12,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Kalender"
               Foreground="White"
               FontWeight="SemiBold"
               FontSize="14" />

    <Grid Grid.Row="1" Margin="0,8,0,6">
      <Border Background="#FF1B2635" CornerRadius="8" />
      <Border x:Name="NowLine"
              Width="2"
              HorizontalAlignment="Left"
              Background="#FFF04444"
              Margin="0,4,0,4" />
      <Canvas x:Name="BlocksCanvas" />
    </Grid>

    <TextBlock Grid.Row="2"
               Text="{Binding StatusText}"
               Foreground="#FFD5E3F0"
               FontSize="11" />
  </Grid>
</Window>
